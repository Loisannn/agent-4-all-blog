---
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />
		<link rel="stylesheet" href="/theme.css" />
		<title>CMS | Agent4All Blog</title>
	</head>
	<body>
		<a class="skip-link" href="#workspace">Skip to CMS workspace</a>
		<div class="app">
			<header class="topbar">
				<a class="topbar-brand" href="/">Agent4All CMS</a>
				<div class="topbar-right">
					<span class="topbar-user" id="userEmail">Checking session</span>
					<button id="logoutButton" class="btn-text" type="button" hidden>退出</button>
				</div>
			</header>

			<!-- ── Auth Panel (minimal, no card) ── -->
			<section id="authPanel" class="auth-panel">
				<form id="authForm" class="auth-form">
					<label>
						邮箱
						<input id="authEmail" type="email" autocomplete="email" required placeholder="admin@example.com" />
					</label>
					<label>
						密码
						<input id="authPassword" type="password" autocomplete="current-password" minlength="8" required placeholder="········" />
					</label>
					<label id="setupTokenField" hidden>
						初始化 token
						<input id="authSetupToken" autocomplete="off" />
					</label>
					<button id="authSubmit" class="btn-primary" type="submit">登录</button>
					<div id="authMessage" class="message" role="status"></div>
				</form>
			</section>

			<div id="workspace" class="workspace" hidden>
				<aside class="sidebar" aria-label="Posts">
					<div class="sidebar-tools">
						<input id="searchInput" type="search" placeholder="搜索文章…" />
						<select id="statusFilter" aria-label="状态">
							<option value="">全部</option>
							<option value="draft">草稿</option>
							<option value="published">已发布</option>
						</select>
						<button id="newPostButton" class="btn-primary" type="button">+ 新建</button>
					</div>
					<div id="postList" class="post-list"></div>
				</aside>

				<!-- ── Editor / Media / Content panels ── -->
				<div id="contentPanel">
					<nav class="cms-nav" id="cmsNav">
						<button class="cms-nav-tab active" data-tab="editor">文章编辑</button>
						<button class="cms-nav-tab" data-tab="media">媒体管理</button>
					</nav>

					<!-- ── Post Editor ── -->
					<form id="editor" class="editor">
						<header class="editor-head">
							<div>
								<p id="editorState" class="editor-state-badge">Draft</p>
								<h1 id="editorTitle">新文章</h1>
							</div>
							<div class="editor-actions">
								<button id="deleteButton" class="btn-text btn-text-danger" type="button">删除</button>
								<button id="unpublishButton" class="btn-text" type="button" hidden>取消发布</button>
								<button id="saveDraftButton" class="btn-text" type="button">存草稿</button>
								<button id="publishButton" class="btn-primary" type="button">发布</button>
							</div>
						</header>

						<div class="editor-body">
							<label>
								标题
								<input id="titleInput" name="title" placeholder="文章标题" required />
							</label>

							<div class="field-row field-row-2">
								<label>
									Slug
									<input id="slugInput" name="slug" placeholder="自动生成" />
								</label>
								<label>
									作者
									<input id="authorNameInput" name="author_name" placeholder="发布者名称" />
								</label>
							</div>

							<label>
								摘要
								<textarea id="excerptInput" name="excerpt" rows="2" placeholder="简短描述…"></textarea>
							</label>

							<div class="media-row">
								<label>
									封面 key
									<input id="coverInput" name="cover_image_key" placeholder="media/uploads/cover.webp" />
								</label>
								<label class="file-field">
									图片
									<input id="mediaInput" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
								</label>
								<button id="uploadCoverButton" class="btn-text" type="button">设为封面</button>
								<button id="insertImageButton" class="btn-text" type="button">插入正文</button>
							</div>

							<label class="content-field">
								正文 Markdown
								<textarea id="contentInput" name="content_markdown" rows="20" placeholder="开始写作…" required></textarea>
							</label>
						</div>

						<div id="message" class="message" role="status"></div>
					</form>

					<!-- ── Media Management Panel ── -->
					<div id="mediaPanel" class="media-panel" hidden>
						<div class="media-toolbar">
							<span class="media-toolbar-title">媒体库</span>
							<span class="media-toolbar-count" id="mediaCount"></span>
						</div>
						<div id="mediaContent" class="media-grid"></div>
						<div id="mediaMessage" class="message" role="status"></div>
					</div>
				</div>
			</div>
		</div>

		<script>
			const state = {
				posts: [],
				current: null,
				setupRequired: false,
				status: 'draft',
				activeTab: 'editor',
				media: [],
			};

			const els = {
				authEmail: document.querySelector('#authEmail'),
				authForm: document.querySelector('#authForm'),
				authMessage: document.querySelector('#authMessage'),
				authPanel: document.querySelector('#authPanel'),
				authPassword: document.querySelector('#authPassword'),
				authSetupToken: document.querySelector('#authSetupToken'),
				authSubmit: document.querySelector('#authSubmit'),
				content: document.querySelector('#contentInput'),
				cover: document.querySelector('#coverInput'),
				authorName: document.querySelector('#authorNameInput'),
				delete: document.querySelector('#deleteButton'),
				unpublish: document.querySelector('#unpublishButton'),
				editorState: document.querySelector('#editorState'),
				editorTitle: document.querySelector('#editorTitle'),
				excerpt: document.querySelector('#excerptInput'),
				insertImage: document.querySelector('#insertImageButton'),
				logout: document.querySelector('#logoutButton'),
				media: document.querySelector('#mediaInput'),
				mediaContent: document.querySelector('#mediaContent'),
				mediaCount: document.querySelector('#mediaCount'),
				mediaPanel: document.querySelector('#mediaPanel'),
				mediaMessage: document.querySelector('#mediaMessage'),
				message: document.querySelector('#message'),
				newPost: document.querySelector('#newPostButton'),
				postList: document.querySelector('#postList'),
				publish: document.querySelector('#publishButton'),
				saveDraft: document.querySelector('#saveDraftButton'),
				search: document.querySelector('#searchInput'),
				setupTokenField: document.querySelector('#setupTokenField'),
				slug: document.querySelector('#slugInput'),
				statusFilter: document.querySelector('#statusFilter'),
				title: document.querySelector('#titleInput'),
				uploadCover: document.querySelector('#uploadCoverButton'),
				userEmail: document.querySelector('#userEmail'),
				workspace: document.querySelector('#workspace'),
				editor: document.querySelector('#editor'),
			};

			init();

			function init() {
				bindEvents();
				resetEditor();
				checkAuth();
			}

			function bindEvents() {
				els.authForm.addEventListener('submit', submitAuth);
				els.logout.addEventListener('click', logout);
				els.newPost.addEventListener('click', resetEditor);
				els.saveDraft.addEventListener('click', () => savePost('draft'));
				els.publish.addEventListener('click', () => savePost('published'));
				els.unpublish.addEventListener('click', () => savePost('draft', true));
				els.delete.addEventListener('click', deleteCurrentPost);
				els.uploadCover.addEventListener('click', () => uploadImage('cover'));
				els.insertImage.addEventListener('click', () => uploadImage('insert'));
				els.search.addEventListener('input', debounce(loadPosts, 250));
				els.statusFilter.addEventListener('change', loadPosts);
				els.title.addEventListener('input', () => {
					els.editorTitle.textContent = els.title.value || '新文章';
				});

				/* CMS tab navigation */
				document.querySelectorAll('.cms-nav-tab').forEach((tab) => {
					tab.addEventListener('click', () => switchTab(tab.dataset.tab));
				});
			}

			/* ── Tab Switching ── */
			function switchTab(tab) {
				state.activeTab = tab;
				document.querySelectorAll('.cms-nav-tab').forEach((t) => {
					t.classList.toggle('active', t.dataset.tab === tab);
				});

				if (tab === 'editor') {
					els.editor.hidden = false;
					els.mediaPanel.hidden = true;
				} else if (tab === 'media') {
					els.editor.hidden = true;
					els.mediaPanel.hidden = false;
					loadMediaAssets();
				}
			}

			/* ── Auth ── */
			async function checkAuth() {
				try {
					const status = await api('/api/auth/status');
					state.setupRequired = status.setupRequired;
					if (status.authenticated) {
						enterApp(status.user);
					} else {
						showAuth(status.setupRequired);
					}
				} catch (error) {
					showAuth(false);
					showAuthMessage(error.message, true);
				}
			}

			function showAuth(setupRequired) {
				state.setupRequired = setupRequired;
				els.workspace.hidden = true;
				els.authPanel.hidden = false;
				els.logout.hidden = true;
				els.userEmail.textContent = setupRequired ? 'Setup required' : 'Not logged in';
				els.setupTokenField.hidden = !setupRequired;
				els.authSubmit.textContent = setupRequired ? '创建管理员' : '登录';
				els.authPassword.autocomplete = setupRequired ? 'new-password' : 'current-password';
				els.authEmail.focus();
			}

			function enterApp(user) {
				els.authPanel.hidden = true;
				els.workspace.hidden = false;
				els.logout.hidden = false;
				els.userEmail.textContent = user?.email || 'Logged in';
				showAuthMessage('');
				loadPosts();
			}

			async function submitAuth(event) {
				event.preventDefault();
				const body = {
					email: els.authEmail.value,
					password: els.authPassword.value,
					name: '',
					setupToken: els.authSetupToken.value,
				};
				const path = state.setupRequired ? '/api/auth/setup' : '/api/auth/login';

				try {
					const { user } = await api(path, {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify(body),
					});
					els.authPassword.value = '';
					enterApp(user);
				} catch (error) {
					showAuthMessage(error.message, true);
				}
			}

			async function logout() {
				try {
					await api('/api/auth/logout', { method: 'POST' });
				} finally {
					state.posts = [];
					resetEditor();
					showAuth(false);
				}
			}

			/* ── Posts ── */
			async function loadPosts() {
				const params = new URLSearchParams();
				if (els.statusFilter.value) params.set('status', els.statusFilter.value);
				if (els.search.value.trim()) params.set('q', els.search.value.trim());

				try {
					const { posts } = await api(`/api/admin/posts?${params}`);
					state.posts = posts;
					renderPostList();
				} catch (error) {
					showMessage(error.message, true);
				}
			}

			function renderPostList() {
				els.postList.innerHTML = '';
				if (!state.posts.length) {
					els.postList.innerHTML = '<p class="empty-state">还没有文章。新建一篇草稿开始写作。</p>';
					return;
				}

				for (const post of state.posts) {
					const button = document.createElement('button');
					button.type = 'button';
					button.className = `post-row ${state.current?.id === post.id ? 'active' : ''}`;
					button.setAttribute('aria-pressed', state.current?.id === post.id ? 'true' : 'false');
					const statusLabel = post.status === 'published' ? '已发布' : '草稿';
					const statusClass = post.status === 'published' ? 'published' : '';
					button.innerHTML = `
						<span class="post-row-title">${escapeHtml(post.title)}</span>
						<span class="post-row-meta">
							<span class="post-status ${statusClass}">${statusLabel}</span>
							${new Date(post.updated_at).toLocaleDateString()}
						</span>
					`;
					button.addEventListener('click', () => loadPost(post.id));
					els.postList.append(button);
				}
			}

			async function loadPost(id) {
				try {
					const { post } = await api(`/api/admin/posts/${id}`);
					state.current = post;
					fillEditor(post);
					renderPostList();
				} catch (error) {
					showMessage(error.message, true);
				}
			}

			function fillEditor(post) {
				state.status = post.status;
				els.title.value = post.title;
				els.slug.value = post.slug;
				els.excerpt.value = post.excerpt || '';
				els.cover.value = post.cover_image_key || '';
				els.authorName.value = post.author_name || '';
				els.content.value = post.content_markdown;
				els.editorTitle.textContent = post.title;
				els.editorState.textContent = post.status === 'published' ? 'Published' : 'Draft';
				els.publish.textContent = post.status === 'published' ? '更新发布' : '发布';
				els.unpublish.hidden = post.status !== 'published';
				els.delete.disabled = false;
			}

			function resetEditor() {
				state.current = null;
				state.status = 'draft';
				els.title.value = '';
				els.slug.value = '';
				els.excerpt.value = '';
				els.cover.value = '';
				els.authorName.value = '';
				els.content.value = '';
				els.editorTitle.textContent = '新文章';
				els.editorState.textContent = 'Draft';
				els.publish.textContent = '发布';
				els.unpublish.hidden = true;
				els.delete.disabled = true;
				renderPostList();
			}

			async function savePost(nextStatus, unpublish = false) {
				let status;
				if (unpublish) {
					/* Explicit unpublish: force to draft */
					status = 'draft';
				} else if (state.current?.status === 'published' && nextStatus === 'published') {
					/* Updating a published post: keep it published (republish) */
					status = 'published';
				} else {
					/* Normal save */
					status = nextStatus;
				}

				const body = {
					title: els.title.value,
					slug: els.slug.value,
					excerpt: els.excerpt.value,
					cover_image_key: els.cover.value,
					author_name: els.authorName.value,
					content_markdown: els.content.value,
					status,
				};
				const path = state.current ? `/api/admin/posts/${state.current.id}` : '/api/admin/posts';
				const method = state.current ? 'PATCH' : 'POST';

				try {
					const { post } = await api(path, {
						method,
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify(body),
					});
					state.current = post;
					fillEditor(post);
					await loadPosts();
					showMessage(unpublish ? '已取消发布' : '已保存');
				} catch (error) {
					showMessage(error.message, true);
				}
			}

			async function deleteCurrentPost() {
				if (!state.current) return;
				const confirmed = confirm('确认删除这篇文章？此操作不可撤销。');
				if (!confirmed) return;
				try {
					await api(`/api/admin/posts/${state.current.id}`, { method: 'DELETE' });
					resetEditor();
					await loadPosts();
					showMessage('已删除');
				} catch (error) {
					showMessage(error.message, true);
				}
			}

			/* ── Media Upload ── */
			async function uploadImage(mode) {
				const file = els.media.files?.[0];
				if (!file) {
					showMessage('请选择图片', true);
					return;
				}

				const form = new FormData();
				form.append('file', file);
				try {
					const { asset, url } = await api('/api/admin/media', {
						method: 'POST',
						body: form,
					});
					if (mode === 'cover') {
						els.cover.value = asset.key;
					} else {
						const markdown = `![${file.name}](${url})`;
						insertAtCursor(els.content, markdown);
					}
					showMessage('图片已上传');
				} catch (error) {
					showMessage(error.message, true);
				}
			}

			/* ── Media Management ── */
			async function loadMediaAssets() {
				try {
					const { assets } = await api('/api/admin/media');
					state.media = assets;
					renderMediaGrid();
				} catch (error) {
					els.mediaContent.innerHTML = `<p class="empty-state">加载媒体库失败：${escapeHtml(error.message)}</p>`;
				}
			}

			function renderMediaGrid() {
				els.mediaCount.textContent = state.media.length ? `(${state.media.length} 个文件)` : '';

				if (!state.media.length) {
					els.mediaContent.innerHTML = '<p class="empty-state">媒体库为空。上传图片后在此处管理。</p>';
					return;
				}

				els.mediaContent.innerHTML = state.media.map((asset) => {
					const safeKey = escapeHtml(asset.key);
					return `
						<article class="media-card">
							<div class="media-card-preview">
								${asset.mime_type.startsWith('image/')
									? `<img src="/media/${encodeURIComponent(asset.key)}" alt="${safeKey}" loading="lazy" />`
									: `<span class="media-icon">&#128196;</span>`
								}
							</div>
							<div class="media-card-body">
								<span class="media-card-filename">${safeKey}</span>
								<span class="media-card-meta">
									<span>${formatBytes(asset.size)}</span>
									<span>${new Date(asset.uploaded_at).toLocaleDateString()}</span>
								</span>
								<button class="btn-text media-refs-toggle" data-id="${asset.id}" type="button" style="height:auto;padding:0.25rem 0.5rem;font-size:0.75rem;margin-top:var(--space-1);">
									查看引用
								</button>
								<div id="refs-${asset.id}" class="media-card-refs" hidden></div>
							</div>
							<div class="media-card-actions">
								<button class="btn-text btn-text-danger media-delete-btn" data-id="${asset.id}" data-key="${safeKey}" type="button">
									删除
								</button>
							</div>
						</article>
					`;
				}).join('');

				/* Bind media card events */
				els.mediaContent.querySelectorAll('.media-refs-toggle').forEach((btn) => {
					btn.addEventListener('click', () => toggleMediaRefs(Number(btn.dataset.id)));
				});

				els.mediaContent.querySelectorAll('.media-delete-btn').forEach((btn) => {
					btn.addEventListener('click', () => deleteMediaAsset(Number(btn.dataset.id), btn.dataset.key));
				});
			}

			async function toggleMediaRefs(id) {
				const refDiv = document.querySelector(`#refs-${id}`);
				if (!refDiv) return;

				if (!refDiv.hidden) {
					refDiv.hidden = true;
					return;
				}

				try {
					const { referencingPosts } = await api(`/api/admin/media?id=${id}`);
					if (referencingPosts.length === 0) {
						refDiv.innerHTML = '<p style="margin:0;color:var(--color-muted);">未被任何文章引用</p>';
					} else {
						refDiv.innerHTML = `
							<details open>
								<summary>被 ${referencingPosts.length} 篇文章引用</summary>
								<ul>
									${referencingPosts.map((p) => `
										<li>
											<a href="/blog/${encodeURIComponent(p.slug)}" target="_blank">${escapeHtml(p.title)}</a>
											<span class="post-ref-status">${p.status === 'published' ? '已发布' : '草稿'}</span>
										</li>
									`).join('')}
								</ul>
							</details>
						`;
					}
					refDiv.hidden = false;
				} catch (error) {
					refDiv.innerHTML = `<p style="margin:0;color:var(--color-danger);">加载失败：${escapeHtml(error.message)}</p>`;
					refDiv.hidden = false;
				}
			}

			async function deleteMediaAsset(id, key) {
				const confirmed = confirm(`确认删除媒体文件 "${key}"？此操作不可撤销。`);
				if (!confirmed) return;

				try {
					await api(`/api/admin/media?id=${id}`, { method: 'DELETE' });
					showMediaMessage('媒体文件已删除');
					await loadMediaAssets();
				} catch (error) {
					showMediaMessage(error.message, true);
				}
			}

			/* ── Utilities ── */
			async function api(path, options = {}) {
				const response = await fetch(path, options);
				const payload = await response.json().catch(() => null);
				if (!response.ok || !payload?.ok) {
					throw new Error(payload?.error?.message || `Request failed (${response.status})`);
				}
				return payload.data;
			}

			function insertAtCursor(textarea, value) {
				const start = textarea.selectionStart || 0;
				const end = textarea.selectionEnd || 0;
				textarea.value = `${textarea.value.slice(0, start)}${value}${textarea.value.slice(end)}`;
				textarea.focus();
				textarea.selectionStart = textarea.selectionEnd = start + value.length;
			}

			function showMessage(message, isError = false) {
				els.message.textContent = message;
				els.message.classList.toggle('error', isError);
			}

			function showMediaMessage(message, isError = false) {
				els.mediaMessage.textContent = message;
				els.mediaMessage.classList.toggle('error', isError);
			}

			function showAuthMessage(message, isError = false) {
				els.authMessage.textContent = message;
				els.authMessage.classList.toggle('error', isError);
			}

			function debounce(fn, wait) {
				let timer;
				return () => {
					clearTimeout(timer);
					timer = setTimeout(fn, wait);
				};
			}

			function escapeHtml(value) {
				return String(value).replace(/[&<>"']/g, (char) => ({
					'&': '&amp;',
					'<': '&lt;',
					'>': '&gt;',
					'"': '&quot;',
					"'": '&#39;',
				})[char]);
			}

			function formatBytes(bytes) {
				if (bytes < 1024) return `${bytes} B`;
				if (bytes < 1048576) return `${(bytes / 1024).toFixed(1)} KB`;
				return `${(bytes / 1048576).toFixed(1)} MB`;
			}
		</script>
	</body>
</html>
